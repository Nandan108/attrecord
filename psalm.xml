<?xml version="1.0"?>
<psalm errorLevel="1" resolveFromConfigFile="true"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config" xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd" findUnusedBaselineEntry="true" findUnusedCode="true" phpVersion="8.1" allConstantsGlobal="true">
    <stubs>
        <file name="vendor/php-stubs/wordpress-stubs/wordpress-stubs.php"/>
    </stubs>

    <projectFiles>
        <directory name="src" />
        <directory name="tests" />
        <ignoreFiles>
            <directory name="vendor" />
            <!-- Runtime double for the WordPress `wpdb` global; Psalm uses the php-stubs stub. -->
            <file name="tests/Support/wpdb-double.php" />
            <!-- Drives the wpdb double via its custom API, which Psalm models as the stub `wpdb`. -->
            <file name="tests/Unit/WpDbSessionTest.php" />
        </ignoreFiles>
    </projectFiles>

    <issueHandlers>
        <!-- Test classes initialise properties in setUp(), not the constructor. -->
        <PropertyNotSetInConstructor>
            <errorLevel type="suppress">
                <directory name="tests" />
            </errorLevel>
        </PropertyNotSetInConstructor>
        <!-- #[\Override] requires PHP 8.3; suppress the nudge for test classes. -->
        <MissingOverrideAttribute>
            <errorLevel type="suppress">
                <directory name="tests" />
            </errorLevel>
        </MissingOverrideAttribute>
        <!-- Test classes and properties are accessed by PHPUnit; Psalm cannot see the callers. -->
        <UnusedClass>
            <errorLevel type="suppress">
                <directory name="tests" />
            </errorLevel>
        </UnusedClass>
        <PossiblyUnusedProperty>
            <errorLevel type="suppress">
                <directory name="tests" />
            </errorLevel>
        </PossiblyUnusedProperty>
    </issueHandlers>
</psalm>
